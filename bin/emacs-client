#!/bin/sh
# Enhanced Emacs client wrapper for FreeBSD
# Starts Emacs daemon if not running

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Check if Emacs daemon is running
if ! pgrep -f "emacs --daemon" > /dev/null; then
    echo "${YELLOW}Emacs daemon not running. Starting...${NC}"
    emacs --daemon >/dev/null 2>&1
    if [ $? -ne 0 ]; then
        echo "${RED}Failed to start Emacs daemon.${NC}"
        exit 1
    else
        echo "${GREEN}Emacs daemon started.${NC}"
    fi
fi

# Check for journal command
if [ "$1" = "journal" ]; then
    shift
    date=""
    if [ -n "$1" ]; then
        date="$1"
        shift
    else
        date=$(date +"%Y%m%d")
    fi
    
    emacsclient -t -e "(progn (find-file \"$HOME/.anthropic/journal/$date.org\") nil)"
    exit $?
fi

# Check for org-capture 
if [ "$1" = "capture" ]; then
    shift
    template=""
    if [ -n "$1" ]; then
        template="$1"
        shift
    else
        template="t"
    fi
    
    emacsclient -t -e "(progn (org-capture nil \"$template\") nil)"
    exit $?
fi

# Default behavior: open files in terminal mode
emacsclient -t "$@"